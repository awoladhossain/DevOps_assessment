# Ignore dependency directories
**/node_modules
**/dist
**/build

# Ignore log files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Ignore environment files
.env
.env.*

# Ignore IDE configs and metadata
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store

# Ignore version control files
.git
.gitignore

# Ignore docker files from being copied inside images
**/Dockerfile
**/.dockerignore
**/.dockerIgnore
