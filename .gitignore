# Dependency directories
node_modules/
/jspm_packages/

# Build outputs
dist/
build/
out/
.next/
.nuxt/

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment and secrets (CRITICAL: Do not commit sensitive files)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env
*.pem
*.key
*.pub
secrets.yaml

# OS metadata
.DS_Store
Thumbs.db

# IDEs and editors
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.settings/

# Keep .vscode settings for workspace schema mapping, but ignore state/history
.vscode/tasks.json
.vscode/launch.json
.vscode/projects.json

# Terraform runtime files
.terraform/
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Terraform variables (sensitive values)
*.tfvars
*.tfvars.json
*override.tf
*override.tf.json

# Terraform lock files (optional to ignore, but usually ignored if working across different OS)
#.terraform.lock.hcl
terraform